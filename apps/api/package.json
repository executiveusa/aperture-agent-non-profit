{
  "name": "@aperture/api",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint api ok'",
    "test": "node --test src/server.test.ts",
    "db:migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "format": "echo 'format api'"
  },
  "dependencies": {
    "@aperture/shared": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "pino": "^9.5.0",
    "pg": "^8.13.0",
    "bullmq": "^5.17.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.1"
  }
}
